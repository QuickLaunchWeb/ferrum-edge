{
  "$schema": "https://www.krakend.io/schema/krakend.json",
  "version": 3,
  "name": "Ferrum Benchmark - KrakenD gRPCs",
  "port": 8443,
  "timeout": "30s",
  "cache_ttl": "0s",
  "max_idle_connections": 500,
  "max_idle_connections_per_host": 500,
  "disable_keep_alives": false,
  "dialer_timeout": "5s",
  "read_timeout": "30s",
  "write_timeout": "30s",
  "idle_timeout": "120s",
  "tls": {
    "public_key": "CERT_PATH",
    "private_key": "KEY_PATH"
  },
  "extra_config": {
    "grpc": {
      "catalog": ["/etc/krakend/proto"],
      "server": {
        "services": [
          {
            "name": "bench.BenchService",
            "backend": [
              {
                "host": ["127.0.0.1:50052"],
                "disable_host_sanitize": true,
                "extra_config": {
                  "backend/grpc": {
                    "use_request_body": true
                  }
                }
              }
            ]
          }
        ]
      }
    }
  },
  "endpoints": [
    {
      "endpoint": "/health",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "host": ["http://127.0.0.1:3010"],
          "url_pattern": "/health",
          "encoding": "no-op"
        }
      ]
    }
  ]
}
