{
  "uid": "ferrum-gateway-overview",
  "title": "Ferrum Gateway Overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["ferrum", "gateway"],
  "timezone": "browser",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "namespace",
        "type": "query",
        "label": "Namespace",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(ferrum_requests_total, namespace)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "proxy_id",
        "type": "query",
        "label": "Proxy",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(ferrum_requests_total{namespace=~\"$namespace\"}, proxy_id)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum by (proxy_id) (rate(ferrum_requests_total{namespace=~\"$namespace\", proxy_id=~\"$proxy_id\"}[5m]))",
          "legendFormat": "{{proxy_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}
      }
    },
    {
      "id": 2,
      "title": "Status code distribution",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum by (status_code) (rate(ferrum_requests_total{namespace=~\"$namespace\", proxy_id=~\"$proxy_id\"}[5m]))",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}
      }
    },
    {
      "id": 3,
      "title": "Error rate (5xx)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(ferrum_requests_total{namespace=~\"$namespace\", proxy_id=~\"$proxy_id\", status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(ferrum_requests_total{namespace=~\"$namespace\", proxy_id=~\"$proxy_id\"}[5m])), 1)",
          "legendFormat": "5xx ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "id": 4,
      "title": "Error rate (4xx)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(ferrum_requests_total{namespace=~\"$namespace\", proxy_id=~\"$proxy_id\", status_code=~\"4..\"}[5m])) / clamp_min(sum(rate(ferrum_requests_total{namespace=~\"$namespace\", proxy_id=~\"$proxy_id\"}[5m])), 1)",
          "legendFormat": "4xx ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.05},
              {"color": "red", "value": 0.2}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "id": 5,
      "title": "Rate limit rejections",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(ferrum_rate_limit_exceeded_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "rate limit/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0
        }
      },
      "options": {
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "id": 6,
      "title": "Client disconnects",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(ferrum_client_disconnects_total{namespace=~\"$namespace\", proxy_id=~\"$proxy_id\"}[5m]))",
          "legendFormat": "disconnects/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        }
      },
      "options": {
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "id": 7,
      "title": "Request latency p50 / p95 / p99",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ferrum_request_duration_ms_bucket{namespace=~\"$namespace\", proxy_id=~\"$proxy_id\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ferrum_request_duration_ms_bucket{namespace=~\"$namespace\", proxy_id=~\"$proxy_id\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(ferrum_request_duration_ms_bucket{namespace=~\"$namespace\", proxy_id=~\"$proxy_id\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0
        }
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },
    {
      "id": 8,
      "title": "Gateway overhead p50 / p95 / p99",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ferrum_edge_overhead_ms_bucket{namespace=~\"$namespace\", proxy_id=~\"$proxy_id\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ferrum_edge_overhead_ms_bucket{namespace=~\"$namespace\", proxy_id=~\"$proxy_id\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(ferrum_edge_overhead_ms_bucket{namespace=~\"$namespace\", proxy_id=~\"$proxy_id\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0
        }
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },
    {
      "id": 9,
      "title": "Backend latency p95 by proxy",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 22},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, proxy_id) (rate(ferrum_backend_duration_ms_bucket{namespace=~\"$namespace\", proxy_id=~\"$proxy_id\"}[5m])))",
          "legendFormat": "{{proxy_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}
      }
    },
    {
      "id": 10,
      "title": "Stream connections (TCP/UDP) by protocol",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 22},
      "targets": [
        {
          "expr": "sum by (protocol) (rate(ferrum_stream_connections_total{namespace=~\"$namespace\", proxy_id=~\"$proxy_id\"}[5m]))",
          "legendFormat": "{{protocol}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0
        }
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },
    {
      "id": 11,
      "title": "Stream disconnects by cause",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 30},
      "targets": [
        {
          "expr": "sum by (cause) (rate(ferrum_stream_disconnects_total{namespace=~\"$namespace\", proxy_id=~\"$proxy_id\"}[5m]))",
          "legendFormat": "{{cause}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}
      }
    },
    {
      "id": 12,
      "title": "Stream disconnect direction (client_to_backend vs backend_to_client)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 30},
      "targets": [
        {
          "expr": "sum by (direction) (rate(ferrum_stream_disconnects_total{namespace=~\"$namespace\", proxy_id=~\"$proxy_id\"}[5m]))",
          "legendFormat": "{{direction}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        }
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    }
  ],
  "annotations": {
    "list": []
  },
  "links": []
}
