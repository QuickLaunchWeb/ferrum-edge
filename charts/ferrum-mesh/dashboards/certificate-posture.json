{
  "uid": "ferrum-certificate-posture",
  "title": "Ferrum Mesh Certificate Posture",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["ferrum", "mesh"],
  "timezone": "browser",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "source",
        "type": "query",
        "label": "Identity source",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(ferrum_mesh_cert_expiry_seconds, source)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "trust_domain",
        "type": "query",
        "label": "Trust domain",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(ferrum_mesh_trust_bundle_version, trust_domain)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Certificates by time to expiry (ascending)",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "min by (spiffe_id, source) (ferrum_mesh_cert_expiry_seconds{source=~\"$source\"})",
          "legendFormat": "",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "displayMode": "color-background-solid"
          },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 86400},
              {"color": "yellow", "value": 604800},
              {"color": "green", "value": 2592000}
            ]
          }
        }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "__name__": true},
            "indexByName": {"spiffe_id": 0, "source": 1, "Value": 2},
            "renameByName": {"Value": "expires_in", "spiffe_id": "SPIFFE ID", "source": "source"}
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [{"field": "expires_in"}]
          }
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 2,
      "title": "Minimum time to expiry (alert thresholds)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 10},
      "targets": [
        {
          "expr": "min(ferrum_mesh_cert_expiry_seconds{source=~\"$source\"})",
          "legendFormat": "min expiry",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 86400},
              {"color": "yellow", "value": 604800},
              {"color": "green", "value": 2592000}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "id": 3,
      "title": "Certs expiring < 7 days",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 10},
      "targets": [
        {
          "expr": "count(ferrum_mesh_cert_expiry_seconds{source=~\"$source\"} < 604800)",
          "legendFormat": "expiring",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "id": 4,
      "title": "Certs expiring < 24 hours",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 10},
      "targets": [
        {
          "expr": "count(ferrum_mesh_cert_expiry_seconds{source=~\"$source\"} < 86400)",
          "legendFormat": "expiring",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "id": 5,
      "title": "CA backend health",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 10},
      "targets": [
        {
          "expr": "min by (ca_type) (ferrum_mesh_ca_health)",
          "legendFormat": "{{ca_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "id": 6,
      "title": "Cert rotation failures (rate, 1h)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "sum by (spiffe_id, source) (increase(ferrum_mesh_cert_rotation_failures_total{source=~\"$source\"}[1h]))",
          "legendFormat": "{{source}} {{spiffe_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max", "sum"]}
      }
    },
    {
      "id": 7,
      "title": "Trust bundle version (monotonic churn)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "max by (trust_domain, source) (ferrum_mesh_trust_bundle_version{trust_domain=~\"$trust_domain\"})",
          "legendFormat": "{{source}} {{trust_domain}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["last"]}
      }
    },
    {
      "id": 8,
      "title": "Trust bundle changes (last 1h)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "targets": [
        {
          "expr": "sum by (trust_domain, source) (changes(ferrum_mesh_trust_bundle_version{trust_domain=~\"$trust_domain\"}[1h]))",
          "legendFormat": "{{source}} {{trust_domain}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },
    {
      "id": 9,
      "title": "SPIFFE federation bundle age",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "targets": [
        {
          "expr": "max by (trust_domain) (ferrum_mesh_federation_bundle_age_seconds{trust_domain=~\"$trust_domain\"})",
          "legendFormat": "{{trust_domain}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 600},
              {"color": "red", "value": 3600}
            ]
          }
        }
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },
    {
      "id": 10,
      "title": "SPIFFE federation poll failures",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 32},
      "targets": [
        {
          "expr": "sum by (trust_domain, endpoint) (rate(ferrum_mesh_federation_poll_failures_total{trust_domain=~\"$trust_domain\"}[5m]))",
          "legendFormat": "{{trust_domain}} {{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}
      }
    }
  ],
  "annotations": {
    "list": []
  },
  "links": []
}
